# Google AI Studio API key for local development only.
# Copy this file to .env and replace the placeholder locally; do not commit .env.
GOOGLE_API_KEY=replace-with-your-google-api-key

# Set to False for AI Studio, True for Vertex AI.
GOOGLE_GENAI_USE_VERTEXAI=False

# Optional Vertex AI placeholders.
# GOOGLE_CLOUD_PROJECT=replace-with-your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
